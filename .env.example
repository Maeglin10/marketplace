# ─── DATABASE ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/marketplace"

# ─── AUTH ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-key-change-in-production

# ─── STRIPE ────────────────────────────────────────────────────────────────────
# Server-side (never exposed to browser)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Client-side (safe to expose)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Payment methods: enable/disable in your Stripe Dashboard
# → https://dashboard.stripe.com/settings/payment_methods
# Supported out-of-the-box via Payment Element:
#   Cards (Visa, Mastercard, Amex, CB), Apple Pay, Google Pay, Stripe Link,
#   SEPA Debit, iDEAL, Bancontact, Klarna, Afterpay/Clearpay, Sofort...

# ─── BRANDING (client config per deployment) ────────────────────────────────────
NEXT_PUBLIC_APP_NAME=ServiceHub
NEXT_PUBLIC_APP_TAGLINE=Hire Services, Grow Your Business
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── PAYMENT CONFIG ────────────────────────────────────────────────────────────
NEXT_PUBLIC_CURRENCY=usd
NEXT_PUBLIC_CURRENCY_SYMBOL=$
NEXT_PUBLIC_COMMISSION_PERCENT=10

# ─── UPLOADTHING ────────────────────────────────────────────────────────────────
# Créer un compte sur https://uploadthing.com → App → API Keys
UPLOADTHING_TOKEN=your-uploadthing-token

# ─── RESEND ─────────────────────────────────────────────────────────────────────
# Créer un compte sur https://resend.com → API Keys
RESEND_API_KEY=re_...
# Adresse d'expédition (domaine vérifié dans Resend)
EMAIL_FROM="Marketplace <noreply@yourdomain.com>"
